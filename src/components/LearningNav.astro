---
import { getCollection } from 'astro:content';
import { Card, CardGrid, Badge } from '@astrojs/starlight/components';

// 1. Language detection
const lang = Astro.url.pathname.split('/')[1] || 'en';

// 2. Fetch the 'docs' collection
const allDocs = await getCollection('docs');

// 3. Filtering and Sorting
const cyberOpsPosts = allDocs
  .filter(post => 
    post && 
    post.id && 
    post.id.startsWith(`${lang}/learning/posts/cyberops/`) &&
    !post.id.endsWith('index.mdx') && 
    !post.id.endsWith('index.md')
  )
  .sort((a, b) => {
    // PRIORITY 1: The 'order' field from frontmatter
    // We use Number() to force comparison if Astro sent it as a string by mistake
    const orderA = a.data.order !== undefined ? Number(a.data.order) : 999;
    const orderB = b.data.order !== undefined ? Number(b.data.order) : 999;

    if (orderA !== orderB) {
      return orderA - orderB;
    }
    
    // PRIORITY 2: Alphabetical sorting by ID if 'order' is missing or equal
    return a.id.localeCompare(b.id);
  });
  // .slice(0, 6) -> REMOVED to display all 99 modules

// DEBUG - Check your terminal to see if 'order' is actually being read
cyberOpsPosts.forEach(p => {
    console.log(`File: ${p.id} | Order: ${p.data.order}`);
});

const labels = {
  en: "Access Module →",
  fr: "Accéder au module →"
};

const emptyState = {
  en: "No modules found in this folder.",
  fr: "Aucun module trouvé dans ce dossier."
};
---

<CardGrid>
  {cyberOpsPosts.map((post) => {
    // Generate clean URL
    const targetSlug = post.slug || post.id.replace(/\.[^/.]+$/, "");
    const href = targetSlug.startsWith('/') ? targetSlug : `/${targetSlug}`;

    return (
      <Card title={post.data.title || "Untitled"}>
        <div style="margin-bottom: 0.75rem; display: flex; gap: 0.5rem; align-items: center;">
          <Badge text="SOC" variant="note" />
          {post.data.order !== undefined && (
            <span style="font-size: 0.8rem; font-family: monospace; color: var(--sl-color-gray-3);">
              #{post.data.order.toString().padStart(2, '0')}
            </span>
          )}
        </div>

        <p style="font-size: 0.9rem; color: var(--sl-color-gray-3); min-height: 3em; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
          {post.data.description || "No description available."}
        </p>
        
        <div style="margin-top: 1rem;">
          <a 
            href={href} 
            style="font-weight: bold; text-decoration: none; color: var(--sl-color-accent-high);"
          >
            {labels[lang] || labels.en}
          </a>
        </div>
      </Card>
    )
  })}
</CardGrid>

{cyberOpsPosts.length === 0 && (
  <p style="text-align: center; font-style: italic; margin-top: 2rem;">
    {emptyState[lang] || emptyState.en}
  </p>
)}