---
import { getCollection } from 'astro:content';
import { Card, CardGrid, Badge } from '@astrojs/starlight/components';

// 1. Language detection (defaults to 'en')
const lang = Astro.url.pathname.split('/')[1] || 'en';

// 2. Fetch the 'docs' collection
const allDocs = await getCollection('docs');

// 3. Filter for CyberOps learning modules
const cyberOpsPosts = allDocs
  .filter(post => 
    post && 
    post.id && 
    post.id.startsWith(`${lang}/learning/posts/cyberops/`) &&
    !post.id.endsWith('index.mdx') && 
    !post.id.endsWith('index.md')
  )
  .sort((a, b) => a.id.localeCompare(b.id)) // Sorts by filename (e.g., 01, 02, 03)
  .slice(0, 6);

const labels = {
  en: "Access Module →",
  fr: "Accéder au module →"
};

const emptyState = {
  en: "No modules found in this folder.",
  fr: "Aucun module trouvé dans ce dossier."
};
---

<CardGrid>
  {cyberOpsPosts.map((post) => {
    // Generate clean URL
    const targetSlug = post.slug || post.id.replace(/\.[^/.]+$/, "");
    const href = targetSlug.startsWith('/') ? targetSlug : `/${targetSlug}`;

    return (
      <Card title={post.data.title || "Untitled"}>
        <div style="margin-bottom: 0.75rem;">
          <Badge text="SOC" variant="note" />
        </div>

        <p style="font-size: 0.9rem; color: var(--sl-color-gray-3); min-height: 3em;">
          {post.data.description || "No description available."}
        </p>
        
        <div style="margin-top: 1rem;">
          <a 
            href={href} 
            style="font-weight: bold; text-decoration: none; color: var(--sl-color-accent-high);"
          >
            {labels[lang] || labels.en}
          </a>
        </div>
      </Card>
    )
  })}
</CardGrid>

{cyberOpsPosts.length === 0 && (
  <p style="text-align: center; font-style: italic; margin-top: 2rem;">
    {emptyState[lang] || emptyState.en}
  </p>
)}